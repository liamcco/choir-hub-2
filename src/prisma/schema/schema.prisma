generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Person {
  id               String                  @id
  groupMemberships PersonGroupMembership[]
  positionsHeld    Position[]              @relation("PositionCurrentHolder")
}

model GroupKind {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  groups      Group[]
}

model Group {
  id            String                  @id @default(uuid())
  kindId        String
  kind          GroupKind               @relation(fields: [kindId], references: [id])
  name          String
  description   String?
  active        Boolean                 @default(true)
  isContainer   Boolean                 @default(false)
  parentGroupId String?
  parentGroup   Group?                  @relation("GroupHierarchy", fields: [parentGroupId], references: [id], onDelete: SetNull)
  childGroups   Group[]                 @relation("GroupHierarchy")
  memberships   PersonGroupMembership[]
  positions     PositionGroup[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([parentGroupId, name])
}

model PersonGroupMembership {
  id       String   @id @default(uuid())
  personId String
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addedAt  DateTime @default(now())

  @@unique([personId, groupId])
}

model Position {
  id                    String          @id @default(uuid())
  name                  String          @unique
  description           String?
  currentHolderPersonId String?
  currentHolder         Person?         @relation("PositionCurrentHolder", fields: [currentHolderPersonId], references: [id], onDelete: SetNull)
  heldSince             DateTime?
  groups                PositionGroup[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model PositionGroup {
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([positionId, groupId])
}
