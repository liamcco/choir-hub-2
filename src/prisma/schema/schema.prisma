generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model GroupKind {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  groups      Group[]
}

model Group {
  id            String                @id @default(uuid())
  kindId        String
  kind          GroupKind             @relation(fields: [kindId], references: [id])
  name          String
  description   String?
  isContainer   Boolean               @default(false)
  parentGroupId String?
  parentGroup   Group?                @relation("GroupHierarchy", fields: [parentGroupId], references: [id], onDelete: SetNull)
  childGroups   Group[]               @relation("GroupHierarchy")
  memberships   UserGroupMembership[]
  positions     PositionGroup[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([parentGroupId, name])
}

model UserGroupMembership {
  id      String   @id @default(uuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId String
  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([userId, groupId])
}

model Position {
  id                  String          @id @default(uuid())
  name                String          @unique
  description         String?
  currentHolderUserId String?
  currentHolder       User?           @relation("PositionCurrentHolder", fields: [currentHolderUserId], references: [id], onDelete: SetNull)
  heldSince           DateTime?
  groups              PositionGroup[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model PositionGroup {
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([positionId, groupId])
}
